# Database
DATABASE_URL=postgresql://taskflow:taskflow_pass@db:5432/taskflow_prod

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Bcrypt
BCRYPT_COST=12

# Uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=10

# Notifications
NOTIF_POLL_SECONDS=30
DUE_SOON_CRON=0 * * * *

# Postgres (for db service)
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_pass
POSTGRES_DB=taskflow_prod